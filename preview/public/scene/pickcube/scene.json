{
  "name": "pick-cube",
  "sim": {
    "timestep": 0.005,
    "gravity": [0, -9.81, 0],
    "substeps": 4
  },
  "entities": [
    {
      "name": "panda",
      "transform": { "pos": [0, 0, 0] },
      "asset": "/scene/pickcube/panda.xml",
      "joint": { "type": "fixed" }
    },
    {
      "name": "dishwasher",
      "transform": { "pos": [1.0, 0, 0] },
      "asset": "/scene/pickcube/dishwasher.xml"
    },
    {
      "name": "box",
      "transform": { "pos": [0.5, 0.02, 0] },
      "mesh": {
        "source": "box",
        "size": [0.04, 0.04, 0.04],
        "color": "#e62626"
      },
      "physics": { "dynamic": true, "mass": 0.02, "friction": 1.0 },
      "joint": { "type": "free" },
      "scripts": [
        {
          "name": "reach",
          "code": "def step(ctx, self):\n    d = ctx.dist('hand', self.id)\n    val = 1.0 - min(1.0, 5.0 * d)\n    ctx.out.reward += val\n    ctx.out.info[self.id + ':reach'] = val"
        },
        {
          "name": "lift",
          "code": "base_z = None\ndef reset(ctx, self):\n    global base_z\n    base_z = ctx.height(self.id)\ndef step(ctx, self):\n    global base_z\n    if base_z is None:\n        base_z = ctx.height(self.id)\n    dz = ctx.height(self.id) - base_z\n    val = min(1.0, max(0.0, dz / 0.1))\n    ctx.out.reward += val\n    if dz > 0.15:\n        ctx.out.success = True\n    ctx.out.info[self.id + ':lift'] = val"
        },
        {
          "name": "randomize",
          "code": "def reset(ctx, self):\n    x = ctx.rand(0.3, 0.7)\n    y_mj = ctx.rand(-0.2, 0.2)\n    ctx.spawn(self.id, [x, y_mj, 0.02])"
        }
      ]
    },
    {
      "name": "target",
      "transform": { "pos": [0.5, 0.3, 0] },
      "mesh": {
        "source": "sphere",
        "radius": 0.025,
        "color": "#26e626",
        "opacity": 0.35
      },
      "physics": { "dynamic": false, "collide": false }
    },
    {
      "name": "side_cam",
      "transform": { "pos": [1.8, 1.4, -0.5] },
      "sensor": { "type": "camera", "resolution": [320, 240], "fov": 50 }
    },
    {
      "name": "overhead_cam",
      "transform": { "pos": [0.5, 1.8, 0] },
      "sensor": { "type": "camera", "resolution": [256, 256], "fov": 65 }
    }
  ],
  "controllers": [
    {
      "name": "teleop",
      "targets": ["panda"],
      "mode": "position",
      "source": "keyboard"
    }
  ],
  "metadata": {
    "instruction": "Pick up the red cube and lift it to the target position",
    "episode_length": 150,
    "based_on": "RoboVerse mujoco_playground.pick — PandaPickCube",
    "robot": "Franka Emika Panda (mujoco_menagerie, collision-only)",
    "default_joint_positions": {
      "joint1": 0.0,
      "joint2": -0.785398,
      "joint3": 0.0,
      "joint4": -2.356194,
      "joint5": 0.0,
      "joint6": 1.570796,
      "joint7": 0.785398,
      "finger_joint1": 0.04,
      "finger_joint2": 0.04
    },
    "keyframe_qpos": [0, -0.785398, 0, -2.356194, 0, 1.570796, 0.785398, 0.04, 0.04,
                      0, 0,
                      0.5, 0, 0.02, 1, 0, 0, 0],
    "keyframe_ctrl": [0, -0.785398, 0, -2.356194, 0, 1.570796, 0.785398, 255,
                      0, 0]
  }
}
